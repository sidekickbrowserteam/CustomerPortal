<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.customerportaltemplate">

    <!-- Internet permission is required for loading remote websites and AdMob -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <!-- If you want to provide a global AdMob App ID in the manifest, you can add it here.
             We initialize ads at runtime only when Ad Unit IDs are configured, so this is optional. -->

        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
